# ──────────────────────────────────────────────────────────────────────────
# Test-only environment. Used by e2e/integration tests, NOT dev or prod.
# These are throwaway secrets — safe because they only touch the disposable
# Docker test DB. Never put real credentials here.
# ──────────────────────────────────────────────────────────────────────────

# Points at the local Docker test DB (docker-compose.test.yml), port 5433.
# No sslmode=require — local Postgres does not use SSL.
DATABASE_URL="postgresql://qa:qa@localhost:5433/contexthub_test"

PORT=4002

# Test JWT secrets (dummy values — fine for tests).
JWT_ACCESS_SECRET=test_access_secret_do_not_use_in_prod
JWT_REFRESH_SECRET=test_refresh_secret_do_not_use_in_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_DAYS=7

# Low bcrypt rounds = much faster tests (real app uses 12).
BCRYPT_ROUNDS=4
MAGIC_LINK_TTL_MIN=15

APP_URL=http://localhost:4002
WEB_URL=http://localhost:3001

# Google OAuth — dummy values; OAuth flow isn't exercised by e2e here.
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4002/api/v1/auth/google/callback

# Prisma 7 loads its query compiler as a WASM module via dynamic import().
# Jest needs this flag to allow dynamic ESM imports in CommonJS test files.
NODE_OPTIONS=--experimental-vm-modules


npm run test:e2e:db:up
npm run test:e2e:migrate
npm run test:e2e
npm run test:e2e:db:down
npm run test:e2e:db:clean